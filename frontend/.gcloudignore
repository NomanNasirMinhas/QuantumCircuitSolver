# Cloud Build upload filters for frontend deploy context (submit from ./frontend).

# VCS
.git
.gitignore

# Build output / deps (must be reinstalled during build)
node_modules/
.next/
out/

# Local env / logs
.env
.env.*
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor / OS artifacts
.DS_Store
Thumbs.db

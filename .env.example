GCP_PROJECT_ID=your-gcp-project-id
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global
CORS_ALLOW_ORIGINS=http://localhost:3000
MAX_PROMPT_LENGTH=2000
MAX_ACTIVE_WORKFLOWS_PER_IP=1
DEBUG_RUNS_DIR=./debug_runs
ACCESS_CODE_MASTER_PASSWORD=change-this-master-password
ACCESS_CODE_RESET_ENDPOINT=/admin/internal/7f1acb4e2a9244be9fd8c6d5a73b1e54/access-codes/reset
ACCESS_CODE_LIST_ENDPOINT=/admin/internal/2bf87f2d15fd43e1b9c4d8f0a56c7a91/access-codes/valid
ACCESS_CODE_STATE_FILE=./access_codes_state.json

# Optional model overrides
TRANSLATOR_MODEL=gemini-3.1-flash-lite-preview
ARCHITECT_MODEL=gemini-3.1-pro-preview
SCIENTIST_MODEL=gemini-3.1-flash-lite-preview
EVALUATOR_MODEL=gemini-3.1-flash-lite-preview
MEDIA_STRUCTURED_MODEL=gemini-3.1-flash-lite-preview
GEMINI_INTERLEAVED_MODEL=gemini-2.5-flash-image-preview
IMAGEN_MODEL=imagen-3.0-generate-002
VEO_MODEL=veo-2.0-generate-001
GEMINI_TTS_MODEL=gemini-2.5-pro-tts
GEMINI_TTS_VOICE=Kore

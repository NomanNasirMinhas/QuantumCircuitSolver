GCP_PROJECT_ID=your-gcp-project-id
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global
CORS_ALLOW_ORIGINS=http://localhost:3000
MAX_PROMPT_LENGTH=2000
MAX_ACTIVE_WORKFLOWS_PER_IP=1
DEBUG_RUNS_DIR=./debug_runs
ACCESS_CODE_MASTER_PASSWORD=
ACCESS_CODE_RESET_ENDPOINT=/admin/access/reset
ACCESS_CODE_LIST_ENDPOINT=/admin/access/list
ACCESS_CODE_STATE_FILE=./access_codes_state.json
ACCESS_CODE_BOOTSTRAP_COUNT=5
RUN_HISTORY_GCS_BUCKET=
RUN_HISTORY_GCS_PREFIX=successful_runs
STORYBOOK_PAGE_COUNT=8

# Optional model overrides
TRANSLATOR_MODEL=gemini-3.1-flash-lite-preview
ARCHITECT_MODEL=gemini-3.1-pro-preview
SCIENTIST_MODEL=gemini-3.1-flash-lite-preview
EVALUATOR_MODEL=gemini-3.1-flash-lite-preview
MEDIA_STORYBOOK_MODEL=gemini-3.1-flash-lite-preview
IMAGEN_MODEL=imagen-3.0-generate-002
GEMINI_TTS_MODEL=gemini-2.5-pro-tts
GEMINI_TTS_VOICE=Kore
